# Window management
keybind = ctrl+shift+n=unbind
keybind = ctrl+enter=unbind
keybind = ctrl+shift+q=unbind
keybind = alt+f4=close_window

# Tab management
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+shift+left=unbind
keybind = ctrl+page_up=unbind
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+right=unbind
keybind = ctrl+page_down=unbind
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=last_tab

# Split management
keybind = ctrl+alt+up=new_split:up
keybind = ctrl+alt+down=new_split:down
keybind = ctrl+alt+left=new_split:left
keybind = ctrl+alt+right=new_split:right
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+o=unbind
keybind = ctrl+super+]=unbind
keybind = ctrl+super+[=unbind
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = ctrl+shift+enter=unbind
keybind = ctrl+super+shift+up=resize_split:up,10
keybind = ctrl+super+shift+down=resize_split:down,10
keybind = ctrl+super+shift+left=resize_split:left,10
keybind = ctrl+super+shift+right=resize_split:right,10

# Copy and paste
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = shift+insert=paste_from_selection

# Scrolling
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = ctrl+shift+page_up=jump_to_prompt:-1
keybind = ctrl+shift+page_down=jump_to_prompt:1

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+plus=unbind
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Config
keybind = ctrl+,=unbind
keybind = ctrl+shift+,=unbind
keybind = ctrl+shift+p=toggle_command_palette

# Inspector
keybind = ctrl+shift+i=unbind

# Scrollback
keybind = ctrl+shift+j=unbind
keybind = ctrl+shift+alt+j=unbind